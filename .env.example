# Mac Voice — environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Speech-to-text engine: "elevenlabs" (cloud) | "whisper" (local)
MACVOICE_ENGINE=elevenlabs

# ElevenLabs Scribe v2 API key
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_your_api_key_here

# Default transcription language: "bg" | "en" | "auto"
MACVOICE_LANG=bg

# Optional: ElevenLabs settings (defaults shown)
# ELEVENLABS_MODEL_ID=scribe_v2
# ELEVENLABS_TIMEOUT=30
